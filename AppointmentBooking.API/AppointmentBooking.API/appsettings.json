{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AppointmentBooking;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJwtTokenGenerationMustBeAtLeast32Characters!",
    "Issuer": "AppointmentBookingAPI",
    "Audience": "AppointmentBookingClient",
    "ExpiryMinutes": 60
  },
  "AuthSettings": {
    "PasswordResetExpiryHours": 1
  },
  "FileStorage": {
    "UploadPath": "Uploads",
    "MaxFileSizeBytes": 10485760
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000", "http://localhost:5174" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
